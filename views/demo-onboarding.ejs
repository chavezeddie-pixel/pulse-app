<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pulse — Configuración Inicial</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
  <style>
    body { background:#1a1a2e; color:#fef9ef; font-family:'Inter',sans-serif; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1rem; }
    .onb { max-width:580px; width:100%; }

    /* Progress bar */
    .onb-progress { display:flex; gap:.4rem; margin-bottom:2rem; }
    .onb-dot { flex:1; height:4px; border-radius:4px; background:rgba(254,249,239,.08); transition:background .3s; }
    .onb-dot.active { background:#f4845f; }
    .onb-dot.done { background:#f9c74f; }

    /* Step container */
    .onb-step { display:none; }
    .onb-step.visible { display:block; animation:fadeUp .35s ease; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

    .onb-step h1 { font-size:1.6rem; font-weight:800; margin:0 0 .4rem; }
    .onb-step .sub { color:#9a8e7e; font-size:.9rem; margin-bottom:1.5rem; line-height:1.6; }

    /* Card style */
    .onb-card { background:rgba(254,249,239,.03); border:1px solid rgba(254,249,239,.08); border-radius:16px; padding:1.5rem; margin-bottom:1rem; }
    .onb-card h3 { margin:0 0 .5rem; font-size:.95rem; color:#f4845f; font-weight:700; }
    .onb-card p { margin:0; font-size:.82rem; color:#9a8e7e; line-height:1.5; }

    /* Form fields */
    .field { margin-bottom:1rem; }
    .field label { display:block; font-size:.78rem; color:#9a8e7e; margin-bottom:.3rem; font-weight:600; text-transform:uppercase; letter-spacing:.03em; }
    .field input, .field select { width:100%; padding:.6rem .9rem; border-radius:10px; border:1px solid rgba(254,249,239,.1); background:rgba(254,249,239,.04); color:#fef9ef; font-size:.9rem; font-family:inherit; box-sizing:border-box; }
    .field input:focus, .field select:focus { outline:none; border-color:#f4845f; }

    /* Habit chips */
    .habit-grid { display:flex; flex-wrap:wrap; gap:.5rem; margin-top:.5rem; }
    .habit-chip { display:flex; align-items:center; gap:.4rem; padding:.45rem .9rem; border-radius:20px; border:1px solid rgba(254,249,239,.12); background:rgba(254,249,239,.03); cursor:pointer; transition:all .2s; font-size:.82rem; }
    .habit-chip:hover { border-color:rgba(244,132,95,.4); }
    .habit-chip.selected { background:rgba(244,132,95,.15); border-color:#f4845f; color:#f4845f; }
    .habit-chip input { display:none; }

    /* Rutina guide */
    .rutina-example { border-radius:10px; overflow:hidden; }
    .rutina-row { display:flex; align-items:center; gap:.5rem; padding:.45rem .7rem; border-bottom:1px solid rgba(254,249,239,.04); font-size:.82rem; }
    .rutina-row:last-child { border-bottom:none; }
    .rutina-time { color:#f4845f; font-family:monospace; font-size:.75rem; min-width:90px; font-weight:600; }
    .rutina-cat { display:inline-block; width:8px; height:8px; border-radius:50%; flex-shrink:0; }
    .rutina-name { color:#fef9ef; }

    /* Navigation */
    .onb-nav { display:flex; gap:.8rem; margin-top:1.5rem; }
    .onb-btn { flex:1; padding:.75rem 1rem; border-radius:10px; border:none; font-size:.95rem; font-weight:600; font-family:inherit; cursor:pointer; transition:all .15s; }
    .onb-btn.secondary { background:rgba(254,249,239,.06); color:#9a8e7e; }
    .onb-btn.secondary:hover { background:rgba(254,249,239,.1); }
    .onb-btn.primary { background:linear-gradient(135deg, #f4845f, #f9c74f); color:#1a1a2e; font-weight:700; }
    .onb-btn.primary:hover { transform:translateY(-1px); box-shadow:0 4px 16px rgba(244,132,95,.3); }

    /* Feature list */
    .feature-list { list-style:none; padding:0; margin:0; }
    .feature-list li { display:flex; align-items:flex-start; gap:.6rem; padding:.5rem 0; font-size:.85rem; }
    .feature-list .icon { color:#f4845f; font-size:1rem; flex-shrink:0; margin-top:.1rem; }
    .feature-list .desc { color:#d4c5b0; line-height:1.45; }
    .feature-list .desc strong { color:#fef9ef; }

    .row-2 { display:grid; grid-template-columns:1fr 1fr; gap:.8rem; }

    .tip { background:rgba(244,132,95,.08); border-left:3px solid #f4845f; padding:.7rem 1rem; border-radius:0 8px 8px 0; font-size:.8rem; color:#f4845f; margin-top:1rem; }
    .tip strong { color:#f9c74f; }
  </style>
</head>
<body>
  <div class="onb">
    <!-- Progress dots -->
    <div class="onb-progress">
      <div class="onb-dot" id="dot1"></div>
      <div class="onb-dot" id="dot2"></div>
      <div class="onb-dot" id="dot3"></div>
      <div class="onb-dot" id="dot4"></div>
    </div>

    <form action="/demo/onboarding/complete" method="POST" id="onbForm">

      <!-- ══════════════ STEP 1: Bienvenida ══════════════ -->
      <div class="onb-step visible" id="step1">
        <h1>Hola, <%= nombre %> 👋</h1>
        <p class="sub">Bienvenido a <strong style="color:#f4845f">Pulse</strong>. Tu sistema personal para entender cómo te sientes realmente. Te guiamos en 2 minutos.</p>

        <div class="onb-card">
          <h3>¿Qué puedes hacer aquí?</h3>
          <ul class="feature-list">
            <li>
              <span class="icon">📊</span>
              <span class="desc"><strong>Check-in 3x al día</strong> — Registra tu energía, ánimo, estrés y enfoque (1-10). Son 30 segundos.</span>
            </li>
            <li>
              <span class="icon">📅</span>
              <span class="desc"><strong>Rutina semanal</strong> — Organiza tu día en bloques horarios (ej: 06:00-06:30 Despertar)</span>
            </li>
            <li>
              <span class="icon">✅</span>
              <span class="desc"><strong>Hábitos</strong> — Lleva el registro de hábitos buenos y malos con rachas visibles</span>
            </li>
            <li>
              <span class="icon">🎯</span>
              <span class="desc"><strong>Objetivos</strong> — Define metas semanales y mensuales con seguimiento</span>
            </li>
            <li>
              <span class="icon">🤖</span>
              <span class="desc"><strong>Coach IA</strong> — Recibe análisis personalizados basados en tu data real</span>
            </li>
            <li>
              <span class="icon">📝</span>
              <span class="desc"><strong>Reflexión + Cuaderno</strong> — Escribe lo que aprendiste y sentiste cada día</span>
            </li>
          </ul>
        </div>

        <div class="onb-nav">
          <a href="/demo/exit" class="onb-btn secondary" style="text-decoration:none;text-align:center;">Salir</a>
          <button type="button" class="onb-btn primary" onclick="goStep(2)">Siguiente →</button>
        </div>
      </div>

      <!-- ══════════════ STEP 2: Perfil basico ══════════════ -->
      <div class="onb-step" id="step2">
        <h1>Cuéntanos de ti</h1>
        <p class="sub">Esto ayuda al Coach IA a darte consejos relevantes. Todo es opcional — puedes saltar lo que quieras.</p>

        <input type="hidden" name="nombre" value="<%= nombre %>" />

        <div class="row-2">
          <div class="field">
            <label>Edad</label>
            <input type="number" name="edad" min="10" max="99" placeholder="Ej: 30" />
          </div>
          <div class="field">
            <label>Género</label>
            <select name="genero">
              <option value="">Prefiero no decir</option>
              <option value="masculino">Masculino</option>
              <option value="femenino">Femenino</option>
              <option value="otro">Otro</option>
            </select>
          </div>
        </div>

        <div class="field">
          <label>Ocupación</label>
          <input type="text" name="ocupacion" placeholder="Ej: Desarrollador, Estudiante, Independiente..." />
        </div>

        <div class="field">
          <label>¿Qué quieres mejorar?</label>
          <input type="text" name="objetivos" placeholder="Ej: Dormir mejor, hacer ejercicio, estudiar más..." />
        </div>

        <div class="field">
          <label>Áreas donde sientes que fallas</label>
          <input type="text" name="areas_mejorar" placeholder="Ej: Disciplina, alimentación, tiempo libre..." />
        </div>

        <div class="onb-nav">
          <button type="button" class="onb-btn secondary" onclick="goStep(1)">← Atrás</button>
          <button type="button" class="onb-btn primary" onclick="goStep(3)">Siguiente →</button>
        </div>
      </div>

      <!-- ══════════════ STEP 3: Habitos iniciales ══════════════ -->
      <div class="onb-step" id="step3">
        <h1>Elige tus hábitos</h1>
        <p class="sub">Toca para seleccionar o deseleccionar. También puedes crear los tuyos propios.</p>

        <div class="onb-card">
          <h3>Hábitos sugeridos <span style="font-weight:400;color:#6b5f52;font-size:.75rem">(toca para activar/desactivar)</span></h3>
          <div class="habit-grid" id="habitGrid">
            <label class="habit-chip" onclick="this.classList.toggle('selected')">
              <input type="checkbox" name="habits" value="Dormir 7+ horas" /> 😴 Dormir 7+ horas
            </label>
            <label class="habit-chip" onclick="this.classList.toggle('selected')">
              <input type="checkbox" name="habits" value="Ejercicio 30min" /> 💪 Ejercicio 30min
            </label>
            <label class="habit-chip" onclick="this.classList.toggle('selected')">
              <input type="checkbox" name="habits" value="Meditar 10min" /> 🧘 Meditar 10min
            </label>
            <label class="habit-chip" onclick="this.classList.toggle('selected')">
              <input type="checkbox" name="habits" value="Leer 20min" /> 📖 Leer 20min
            </label>
            <label class="habit-chip" onclick="this.classList.toggle('selected')">
              <input type="checkbox" name="habits" value="Estudiar 1h" /> 📚 Estudiar 1h
            </label>
            <label class="habit-chip" onclick="this.classList.toggle('selected')">
              <input type="checkbox" name="habits" value="Agua 2L" /> 💧 Agua 2L
            </label>
            <label class="habit-chip" onclick="this.classList.toggle('selected')">
              <input type="checkbox" name="habits" value="Sin redes 2h" /> 📵 Sin redes 2h
            </label>
            <label class="habit-chip" onclick="this.classList.toggle('selected')">
              <input type="checkbox" name="habits" value="Comer saludable" /> 🥗 Comer saludable
            </label>
            <label class="habit-chip" onclick="this.classList.toggle('selected')">
              <input type="checkbox" name="habits" value="Caminar 30min" /> 🚶 Caminar 30min
            </label>
            <label class="habit-chip" onclick="this.classList.toggle('selected')">
              <input type="checkbox" name="habits" value="Journaling" /> ✍️ Journaling
            </label>
          </div>
        </div>

        <!-- Crear hábitos propios -->
        <div class="onb-card" style="margin-top:.5rem">
          <h3>➕ Crear hábito propio</h3>
          <p style="font-size:.78rem;color:#9a8e7e;margin-bottom:.6rem">Si quieres agregar más u otros hábitos, puedes crearlos aquí. También podrás crear más dentro de la app.</p>
          <div style="display:flex;gap:.4rem;margin-bottom:.5rem">
            <input type="text" id="customHabitInput" placeholder="Ej: Correr 5km, Yoga, No fumar..." style="flex:1;padding:.5rem .7rem;border-radius:8px;border:1px solid rgba(254,249,239,.1);background:rgba(254,249,239,.04);color:#fef9ef;font-size:.82rem;font-family:inherit;" />
            <button type="button" onclick="addCustomHabit()" style="padding:.5rem .8rem;border-radius:8px;border:none;background:linear-gradient(135deg,#f4845f,#f9c74f);color:#1a1a2e;font-weight:700;font-size:.82rem;cursor:pointer;font-family:inherit;white-space:nowrap;">+ Agregar</button>
          </div>
          <div id="customHabitsList" class="habit-grid"></div>
        </div>

        <div class="tip">
          <strong>Tip:</strong> Empieza con 3-5 hábitos. Es mejor ser consistente con pocos que intentar muchos y abandonar.
        </div>

        <div class="onb-nav">
          <button type="button" class="onb-btn secondary" onclick="goStep(2)">← Atrás</button>
          <button type="button" class="onb-btn primary" onclick="goStep(4)">Siguiente →</button>
        </div>
      </div>

      <!-- ══════════════ STEP 4: Rutina (guia) ══════════════ -->
      <div class="onb-step" id="step4">
        <h1>La Rutina ⏰</h1>
        <p class="sub">La rutina es el corazón de Pulse. Defines bloques horarios para cada día de la semana. Así se ve:</p>

        <div class="onb-card">
          <h3>Ejemplo de rutina (Lunes)</h3>
          <div class="rutina-example">
            <div class="rutina-row">
              <span class="rutina-time">06:00 - 06:10</span>
              <span class="rutina-cat" style="background:#60a5fa"></span>
              <span class="rutina-name">Despertar</span>
            </div>
            <div class="rutina-row">
              <span class="rutina-time">06:10 - 06:30</span>
              <span class="rutina-cat" style="background:#60a5fa"></span>
              <span class="rutina-name">Ducha y preparación</span>
            </div>
            <div class="rutina-row">
              <span class="rutina-time">06:30 - 07:00</span>
              <span class="rutina-cat" style="background:#2dd4bf"></span>
              <span class="rutina-name">Desayuno</span>
            </div>
            <div class="rutina-row">
              <span class="rutina-time">07:00 - 07:30</span>
              <span class="rutina-cat" style="background:#94a3b8"></span>
              <span class="rutina-name">Trayecto al trabajo</span>
            </div>
            <div class="rutina-row">
              <span class="rutina-time">07:30 - 12:00</span>
              <span class="rutina-cat" style="background:#f4845f"></span>
              <span class="rutina-name">Bloque de trabajo</span>
            </div>
            <div class="rutina-row">
              <span class="rutina-time">12:00 - 13:00</span>
              <span class="rutina-cat" style="background:#2dd4bf"></span>
              <span class="rutina-name">Almuerzo</span>
            </div>
            <div class="rutina-row">
              <span class="rutina-time">18:00 - 19:00</span>
              <span class="rutina-cat" style="background:#34d399"></span>
              <span class="rutina-name">Ejercicio</span>
            </div>
            <div class="rutina-row">
              <span class="rutina-time">22:00 - 22:30</span>
              <span class="rutina-cat" style="background:#fb7185"></span>
              <span class="rutina-name">Cierre del día</span>
            </div>
          </div>
        </div>

        <div class="onb-card">
          <h3>¿Cómo funciona?</h3>
          <ul class="feature-list">
            <li>
              <span class="icon">1.</span>
              <span class="desc">Ve a <strong>Rutina</strong> en el menú lateral</span>
            </li>
            <li>
              <span class="icon">2.</span>
              <span class="desc">Selecciona un <strong>día de la semana</strong> (Lunes, Martes...)</span>
            </li>
            <li>
              <span class="icon">3.</span>
              <span class="desc">Haz click en <strong>"+ Agregar bloque"</strong> y define hora inicio, fin y actividad</span>
            </li>
            <li>
              <span class="icon">4.</span>
              <span class="desc">La app asigna <strong>colores por categoría</strong> automáticamente</span>
            </li>
            <li>
              <span class="icon">5.</span>
              <span class="desc">Puedes <strong>copiar un día a otro</strong> para no repetir trabajo</span>
            </li>
            <li>
              <span class="icon">6.</span>
              <span class="desc">Marca los bloques como <strong>completados</strong> durante el día</span>
            </li>
          </ul>
        </div>

        <div class="tip">
          <strong>Tip:</strong> No necesitas llenar todos los bloques de una vez. Empieza con tu mañana y tu noche, y ve agregando el resto poco a poco.
        </div>

        <div class="onb-nav">
          <button type="button" class="onb-btn secondary" onclick="goStep(3)">← Atrás</button>
          <button type="submit" class="onb-btn primary">¡Comenzar! 🚀</button>
        </div>
      </div>

    </form>
  </div>

  <script>
    var currentStep = <%= step %>;
    updateDots();

    function goStep(n) {
      document.querySelectorAll('.habit-chip').forEach(function(chip) {
        var cb = chip.querySelector('input[type=checkbox]');
        cb.checked = chip.classList.contains('selected');
      });

      document.getElementById('step' + currentStep).classList.remove('visible');
      currentStep = n;
      document.getElementById('step' + currentStep).classList.add('visible');
      updateDots();
      window.scrollTo(0, 0);
    }

    function updateDots() {
      for (var i = 1; i <= 4; i++) {
        var dot = document.getElementById('dot' + i);
        dot.className = 'onb-dot';
        if (i < currentStep) dot.classList.add('done');
        if (i === currentStep) dot.classList.add('active');
      }
    }

    // Add custom habit
    function addCustomHabit() {
      var inp = document.getElementById('customHabitInput');
      var val = (inp.value || '').trim();
      if (!val) return;
      var container = document.getElementById('customHabitsList');
      var chip = document.createElement('label');
      chip.className = 'habit-chip selected';
      chip.onclick = function() { this.classList.toggle('selected'); };
      chip.innerHTML = '<input type="checkbox" name="habits" value="' + val.replace(/"/g, '&quot;') + '" checked /> ✨ ' + val;
      container.appendChild(chip);
      inp.value = '';
      inp.focus();
    }

    // Enter key on custom habit input
    document.getElementById('customHabitInput').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); addCustomHabit(); }
    });

    document.getElementById('onbForm').addEventListener('submit', function() {
      document.querySelectorAll('.habit-chip').forEach(function(chip) {
        var cb = chip.querySelector('input[type=checkbox]');
        cb.checked = chip.classList.contains('selected');
      });
    });
  </script>
</body>
</html>
