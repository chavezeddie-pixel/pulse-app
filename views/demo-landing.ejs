<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pulse — Know how you're really doing</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }

    body {
      font-family:'Inter',sans-serif; background:#1a1a2e; color:#fef9ef;
      min-height:100vh; overflow-x:hidden;
    }

    /* ── Ambient glow (warm) ── */
    .glow {
      position:fixed; top:-25%; left:50%; transform:translateX(-50%);
      width:700px; height:450px; border-radius:50%;
      background:radial-gradient(ellipse, rgba(244,132,95,.1) 0%, rgba(249,199,79,.06) 40%, transparent 70%);
      pointer-events:none; z-index:0;
    }
    .glow-2 {
      position:fixed; bottom:-15%; right:-5%;
      width:400px; height:350px; border-radius:50%;
      background:radial-gradient(ellipse, rgba(249,199,79,.07) 0%, transparent 60%);
      pointer-events:none; z-index:0;
    }

    .page { position:relative; z-index:1; }

    /* ── Hero ── */
    .hero {
      min-height:100vh; display:flex; flex-direction:column;
      align-items:center; justify-content:center;
      padding:2rem 1.5rem; text-align:center;
    }

    .hero-badge {
      display:inline-flex; align-items:center; gap:.4rem;
      background:rgba(244,132,95,.1); border:1px solid rgba(244,132,95,.25);
      color:#f4845f; padding:.35rem .9rem; border-radius:100px;
      font-size:.72rem; font-weight:600; letter-spacing:.03em;
      margin-bottom:1.5rem; text-transform:uppercase;
    }
    .hero-badge .dot { width:6px; height:6px; border-radius:50%; background:#f4845f; animation:blink 2s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* ── Logo breathing ── */
    .hero-logo-wrap {
      position:relative;
      width:clamp(140px,30vw,200px);
      height:clamp(140px,30vw,200px);
      margin-bottom:1.5rem;
    }
    .hero-logo {
      width:100%; height:100%;
      object-fit:contain;
      border-radius:22%;
      animation:breathe 4s ease-in-out infinite;
      position:relative;
      z-index:2;
      filter:drop-shadow(0 0 30px rgba(244,132,95,.25));
    }
    .hero-logo-glow {
      position:absolute;
      inset:-15%;
      border-radius:30%;
      background:radial-gradient(circle, rgba(244,132,95,.18) 0%, rgba(249,199,79,.08) 50%, transparent 70%);
      animation:breatheGlow 4s ease-in-out infinite;
      z-index:1;
    }
    @keyframes breathe {
      0%, 100% { transform:scale(1); filter:drop-shadow(0 0 20px rgba(244,132,95,.2)); }
      50% { transform:scale(1.06); filter:drop-shadow(0 0 45px rgba(244,132,95,.4)); }
    }
    @keyframes breatheGlow {
      0%, 100% { opacity:.5; transform:scale(1); }
      50% { opacity:1; transform:scale(1.1); }
    }

    .hero-title {
      font-size:clamp(2.8rem,7vw,4.5rem); font-weight:800;
      line-height:1.05; letter-spacing:-.03em;
      max-width:700px; margin-bottom:1.2rem;
    }
    .hero-title .accent {
      background:linear-gradient(135deg, #f4845f, #f9c74f);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent;
      background-clip:text;
    }

    .hero-question {
      font-size:clamp(1.05rem,2.5vw,1.25rem); color:#d4c5b0;
      max-width:560px; line-height:1.7; margin-bottom:1.2rem; font-weight:300;
    }

    .hero-explain {
      font-size:clamp(.9rem,2vw,1rem); color:#9a8e7e;
      max-width:520px; line-height:1.7; margin-bottom:2.5rem;
    }

    /* ── CTA form ── */
    .hero-cta {
      display:flex; gap:.5rem; width:100%; max-width:420px;
    }
    .hero-input {
      flex:1; padding:.85rem 1.2rem; border-radius:14px;
      border:1px solid rgba(254,249,239,.12); background:rgba(254,249,239,.05);
      color:#fef9ef; font-size:1rem; font-family:inherit;
      backdrop-filter:blur(10px); transition:border-color .2s;
    }
    .hero-input:focus { outline:none; border-color:#f4845f; }
    .hero-input::placeholder { color:#6b5f52; }
    .hero-btn {
      padding:.85rem 1.8rem; border-radius:14px; border:none;
      background:linear-gradient(135deg, #f4845f, #f9c74f);
      color:#1a1a2e; font-size:.95rem; font-weight:700; font-family:inherit;
      cursor:pointer; transition:all .2s; white-space:nowrap;
    }
    .hero-btn:hover { transform:translateY(-2px); box-shadow:0 8px 30px rgba(244,132,95,.35); }

    .hero-note {
      margin-top:1rem; font-size:.78rem; color:#6b5f52; line-height:1.5;
    }

    /* ── Scroll indicator ── */
    .scroll-hint {
      position:absolute; bottom:2rem; left:50%; transform:translateX(-50%);
      display:flex; flex-direction:column; align-items:center; gap:.3rem;
      color:#4a4252; font-size:.65rem; letter-spacing:.1em; text-transform:uppercase;
      animation:float 3s ease-in-out infinite;
    }
    @keyframes float { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }
    .scroll-arrow { width:20px; height:20px; border-right:2px solid #4a4252; border-bottom:2px solid #4a4252; transform:rotate(45deg); }

    /* ── Sections ── */
    .section {
      padding:5rem 1.5rem; max-width:900px; margin:0 auto;
    }
    .section-label {
      font-size:.7rem; font-weight:700; text-transform:uppercase;
      letter-spacing:.12em; color:#f4845f; margin-bottom:.8rem;
    }
    .section-title {
      font-size:clamp(1.6rem,4vw,2.4rem); font-weight:700;
      line-height:1.2; letter-spacing:-.02em; margin-bottom:1rem;
    }
    .section-desc {
      font-size:1rem; color:#9a8e7e; line-height:1.7; max-width:600px; margin-bottom:2.5rem;
    }

    /* ── Problem cards ── */
    .problem-grid {
      display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;
    }
    @media(max-width:600px) { .problem-grid { grid-template-columns:1fr; } }

    .problem-card {
      padding:1.5rem; border-radius:16px;
      background:rgba(254,249,239,.02); border:1px solid rgba(254,249,239,.06);
      transition:border-color .3s, transform .3s;
    }
    .problem-card:hover { border-color:rgba(244,132,95,.3); transform:translateY(-2px); }
    .pc-icon { font-size:1.5rem; margin-bottom:.7rem; }
    .pc-title { font-weight:700; font-size:.95rem; margin-bottom:.3rem; color:#fef9ef; }
    .pc-desc { font-size:.82rem; color:#8a7e6e; line-height:1.55; }

    /* ── Steps ── */
    .steps { display:flex; flex-direction:column; gap:1.5rem; }
    .step {
      display:flex; gap:1.2rem; align-items:flex-start;
      padding:1.2rem; border-radius:14px;
      background:rgba(254,249,239,.02); border:1px solid rgba(254,249,239,.04);
    }
    .step-num {
      width:42px; height:42px; border-radius:12px; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      font-weight:700; font-size:1.1rem;
      background:rgba(244,132,95,.12); color:#f4845f;
    }
    .step-content {}
    .step-title { font-weight:700; font-size:.95rem; margin-bottom:.25rem; }
    .step-desc { font-size:.84rem; color:#8a7e6e; line-height:1.55; }

    /* ── Modules grid ── */
    .modules-grid {
      display:grid; grid-template-columns:repeat(3, 1fr); gap:1rem;
    }
    @media(max-width:700px) { .modules-grid { grid-template-columns:1fr 1fr; } }
    @media(max-width:400px) { .modules-grid { grid-template-columns:1fr; } }

    .module-card {
      padding:1.3rem; border-radius:14px; text-align:center;
      background:rgba(254,249,239,.02); border:1px solid rgba(254,249,239,.06);
      transition:border-color .3s, transform .3s;
    }
    .module-card:hover { border-color:rgba(249,199,79,.3); transform:translateY(-2px); }
    .module-icon { font-size:1.8rem; margin-bottom:.6rem; }
    .module-name { font-weight:700; font-size:.88rem; margin-bottom:.25rem; }
    .module-desc { font-size:.75rem; color:#8a7e6e; line-height:1.45; }

    /* ── Quote ── */
    .quote-section { text-align:center; padding:4rem 1.5rem; }
    .quote {
      font-size:clamp(1.15rem,3vw,1.6rem); font-weight:300; font-style:italic;
      color:#d4c5b0; line-height:1.6; max-width:600px; margin:0 auto 1rem;
    }
    .quote-dash { width:40px; height:2px; background:linear-gradient(90deg, #f4845f, #f9c74f); margin:0 auto; border-radius:2px; }

    /* ── Final CTA ── */
    .final-cta {
      text-align:center; padding:3rem 1.5rem 5rem;
      max-width:600px; margin:0 auto;
    }
    .final-cta h2 {
      font-size:clamp(1.4rem,4vw,2rem); font-weight:700; margin-bottom:.8rem;
    }
    .final-cta .final-desc {
      color:#9a8e7e; font-size:.95rem; line-height:1.65; margin-bottom:2rem;
    }
    .final-form {
      display:flex; gap:.5rem; max-width:420px; margin:0 auto;
    }
    .final-note {
      margin-top:.8rem; font-size:.75rem; color:#6b5f52;
    }

    /* ── Footer ── */
    .footer {
      text-align:center; padding:2rem 1rem;
      border-top:1px solid rgba(254,249,239,.04);
      font-size:.7rem; color:#4a4252;
    }
    .footer a { color:#6b5f52; text-decoration:none; }
    .footer a:hover { color:#9a8e7e; }

    /* ── Responsive ── */
    @media(max-width:500px) {
      .hero-cta, .final-form { flex-direction:column; }
      .hero-btn, .final-form .hero-btn { width:100%; }
    }
  </style>
</head>
<body>
  <div class="glow"></div>
  <div class="glow-2"></div>

  <div class="page">

    <!-- ════════════ HERO ════════════ -->
    <section class="hero">
      <div class="hero-badge">
        <span class="dot"></span> Demo gratuita
      </div>

      <div class="hero-logo-wrap">
        <div class="hero-logo-glow"></div>
        <img src="/img/logo-pulse.png" alt="Pulse" class="hero-logo" />
      </div>

      <p class="hero-question">
        ¿Alguna vez sientes que los días se pasan sin que te des cuenta?
        Que llegas a la noche sin saber si fue un buen día o uno malo?
      </p>

      <p class="hero-explain">
        Pulse te ayuda a parar <strong style="color:#f4845f">3 veces al día</strong> y preguntarte:
        ¿cómo estoy realmente? Energía, ánimo, estrés, enfoque.
        En 30 segundos registras tu estado y con el tiempo
        descubres patrones que no sabías que tenías.
      </p>

      <form class="hero-cta" action="/demo/start" method="POST">
        <input type="text" name="nombre" class="hero-input" placeholder="Tu nombre" required autocomplete="off" />
        <button type="submit" class="hero-btn">Quiero probarlo</button>
      </form>

      <p class="hero-note">
        Es gratis. Sin registro. Sin datos personales.<br/>
        Solo tú y tu honestidad.
      </p>

      <div class="scroll-hint">
        <span>Conoce más</span>
        <div class="scroll-arrow"></div>
      </div>
    </section>

    <!-- ════════════ ¿TE SUENA FAMILIAR? ════════════ -->
    <section class="section">
      <div class="section-label">¿Te suena familiar?</div>
      <h2 class="section-title">Cosas que sentimos pero no decimos</h2>

      <div class="problem-grid">
        <div class="problem-card">
          <div class="pc-icon">😶</div>
          <div class="pc-title">"Llego al final del día y no sé en qué se fue"</div>
          <div class="pc-desc">Los días pasan en piloto automático. No es que sean malos — es que no los estás viviendo con intención.</div>
        </div>
        <div class="problem-card">
          <div class="pc-icon">🔋</div>
          <div class="pc-title">"Ando sin energía pero no sé por qué"</div>
          <div class="pc-desc">Duermes, comes, trabajas... pero algo no cuadra. Sin datos, es imposible saber qué te está drenando.</div>
        </div>
        <div class="problem-card">
          <div class="pc-icon">🔄</div>
          <div class="pc-title">"Empiezo hábitos y a la semana ya los dejé"</div>
          <div class="pc-desc">No es falta de voluntad. Es que no tenías un sistema que te acompañe y te muestre tu progreso real.</div>
        </div>
        <div class="problem-card">
          <div class="pc-icon">🌫️</div>
          <div class="pc-title">"Siento que vivo en piloto automático"</div>
          <div class="pc-desc">El mismo loop todos los días. Pulse te ayuda a romperlo con una pregunta simple: ¿cómo estás ahora mismo?</div>
        </div>
      </div>
    </section>

    <!-- ════════════ CÓMO FUNCIONA ════════════ -->
    <section class="section">
      <div class="section-label">Así funciona</div>
      <h2 class="section-title">3 pasos. Sin complicaciones.</h2>
      <p class="section-desc">
        No necesitas una hora para configurarlo. En 60 segundos ya estás registrando cómo te sientes.
      </p>

      <div class="steps">
        <div class="step">
          <div class="step-num">☀️</div>
          <div class="step-content">
            <div class="step-title">3 check-ins al día</div>
            <div class="step-desc">Mañana, tarde y noche. 4 sliders: energía, ánimo, estrés y enfoque. La pantalla se toma la app hasta que lo hagas — porque tu bienestar es lo primero. Son 30 segundos.</div>
          </div>
        </div>
        <div class="step">
          <div class="step-num">🧱</div>
          <div class="step-content">
            <div class="step-title">Construyes tu sistema</div>
            <div class="step-desc">Hábitos buenos y malos con rachas visibles. Rutina por bloques horarios. Objetivos del día. Todo conectado para que veas el panorama completo.</div>
          </div>
        </div>
        <div class="step">
          <div class="step-num">🔍</div>
          <div class="step-content">
            <div class="step-title">Descubres tus patrones</div>
            <div class="step-desc">Con datos reales ves qué te sube la energía, qué te drena, y cuándo eres más productivo. El coach con IA analiza tu semana y te da recomendaciones concretas.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════ QUÉ INCLUYE ════════════ -->
    <section class="section">
      <div class="section-label">Qué incluye</div>
      <h2 class="section-title">Un sistema completo para entenderte</h2>

      <div class="modules-grid">
        <div class="module-card">
          <div class="module-icon">📊</div>
          <div class="module-name">Estado 3x/día</div>
          <div class="module-desc">Energía, ánimo, estrés y enfoque. Imposible de ignorar.</div>
        </div>
        <div class="module-card">
          <div class="module-icon">✅</div>
          <div class="module-name">Hábitos</div>
          <div class="module-desc">Buenos y malos. Con rachas, porcentajes y diagnóstico cruzado.</div>
        </div>
        <div class="module-card">
          <div class="module-icon">📅</div>
          <div class="module-name">Rutina</div>
          <div class="module-desc">Bloques horarios para cada día. Colores por categoría.</div>
        </div>
        <div class="module-card">
          <div class="module-icon">📝</div>
          <div class="module-name">Diario</div>
          <div class="module-desc">Reflexiones, aprendizajes y notas del día.</div>
        </div>
        <div class="module-card">
          <div class="module-icon">🎯</div>
          <div class="module-name">Objetivos</div>
          <div class="module-desc">Metas semanales y mensuales con seguimiento visual.</div>
        </div>
        <div class="module-card">
          <div class="module-icon">🤖</div>
          <div class="module-name">Coach IA</div>
          <div class="module-desc">Análisis personalizado basado en tu data real.</div>
        </div>
      </div>
    </section>

    <!-- ════════════ QUOTE ════════════ -->
    <section class="quote-section">
      <blockquote class="quote">
        "No necesitas otra app de productividad.<br/>
        Necesitas entenderte."
      </blockquote>
      <div class="quote-dash"></div>
    </section>

    <!-- ════════════ CTA FINAL ════════════ -->
    <section class="final-cta">
      <h2>Estamos construyendo Pulse y nos importa tu opinión</h2>
      <p class="final-desc">
        Pruébalo, úsalo unos días y cuéntanos qué piensas.
        Tu feedback nos ayuda a hacer algo que realmente sirva.
      </p>
      <form class="final-form" action="/demo/start" method="POST">
        <input type="text" name="nombre" class="hero-input" placeholder="Tu nombre" required autocomplete="off" />
        <button type="submit" class="hero-btn">Entrar al demo</button>
      </form>
      <p class="final-note">Toma 2 minutos configurar. Sin registro. Sin datos personales. 🙌</p>
    </section>

    <!-- ════════════ FOOTER ════════════ -->
    <footer class="footer">
      Pulse &mdash; Know how you're really doing
      &nbsp;&middot;&nbsp;
      <a href="/admin">Admin</a>
    </footer>

  </div>
</body>
</html>
