<script>
function toggleEditar() {
  var f = document.getElementById('form-editar');
  f.style.display = f.style.display === 'none' ? 'block' : 'none';
  if (f.style.display === 'block') f.scrollIntoView({ behavior:'smooth', block:'start' });
}
function toggleSeccion(id, header) {
  var el = document.getElementById(id);
  var arrow = document.getElementById('arrow-' + id);
  var visible = el.style.display !== 'none';
  el.style.display = visible ? 'none' : 'block';
  arrow.textContent = visible ? '▸ ver' : '▴ ocultar';
}
function selectOpcion(input) {
  document.querySelectorAll('input[name="'+input.name+'"]').forEach(function(i){ i.closest('.opcion-card').classList.remove('checked'); });
  input.closest('.opcion-card').classList.add('checked');
}
function toggleOpcion(input) {
  input.closest('.opcion-card').classList.toggle('checked', input.checked);
}
</script>

