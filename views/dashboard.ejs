<%- include('partials/header') %>

<style>
/* ═══════════════════════════════
   DASHBOARD
═══════════════════════════════ */

/* ── Hero ── */
.dash-hero {
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius-xl);
  padding:1.5rem 1.75rem;
  margin-bottom:1.1rem;
  box-shadow:var(--shadow-sm);
  display:flex; align-items:center; gap:1.75rem; flex-wrap:wrap;
  position:relative; overflow:hidden;
}
.dash-hero::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:2px;
  background:linear-gradient(90deg, var(--accent), var(--green), var(--indigo));
  opacity:.7;
}
.hero-score-wrap { flex-shrink:0; position:relative; }
.hero-score-center {
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  text-align:center; line-height:1;
}
.hero-info { flex:1; min-width:180px; }
.hero-greeting { font-size:.65rem; text-transform:uppercase; letter-spacing:.12em; color:var(--text-muted); margin-bottom:.2rem; }
.hero-date     { font-family:var(--font-mono); font-size:1.35rem; font-weight:700; line-height:1.1; margin-bottom:.5rem; }
.hero-badges   { display:flex; gap:.4rem; flex-wrap:wrap; align-items:center; }
.hero-actions  { display:flex; flex-direction:column; gap:.4rem; flex-shrink:0; }

/* ── Vitals strip ── */
.vitals-strip {
  display:grid; grid-template-columns:repeat(5,1fr);
  gap:.55rem; margin-bottom:1.1rem;
}
@media(max-width:700px){ .vitals-strip { grid-template-columns:repeat(3,1fr); } }
@media(max-width:420px){ .vitals-strip { grid-template-columns:repeat(2,1fr); } }

.vital-card {
  background:var(--surface); border:1px solid var(--border);
  border-radius:var(--radius-lg); padding:.75rem .7rem;
  display:flex; flex-direction:column; gap:.2rem;
  box-shadow:var(--shadow-sm); position:relative; overflow:hidden;
}
.vital-card::after {
  content:''; position:absolute; bottom:0; left:0; right:0; height:2px;
}
.vital-icon { font-size:1.1rem; line-height:1; margin-bottom:.05rem; }
.vital-val  { font-family:var(--font-mono); font-size:1.35rem; font-weight:700; line-height:1; }
.vital-lbl  { font-size:.6rem; text-transform:uppercase; letter-spacing:.07em; color:var(--text-muted); }
.vital-bar  { height:2px; background:var(--surface-3); border-radius:99px; overflow:hidden; margin-top:.35rem; }
.vital-bar-fill { height:100%; border-radius:99px; }

/* ── Coach banner ── */
.coach-banner {
  display:flex; align-items:flex-start; gap:.9rem;
  padding:.95rem 1.1rem; border-radius:var(--radius-lg);
  border:1px solid; margin-bottom:1.1rem; flex-wrap:wrap;
}
.coach-icon  { font-size:1.3rem; flex-shrink:0; margin-top:.1rem; }
.coach-body  { flex:1; min-width:200px; }
.coach-label { font-family:var(--font-mono); font-size:.58rem; text-transform:uppercase; letter-spacing:.1em; margin-bottom:.2rem; font-weight:700; }
.coach-txt   { font-size:.84rem; line-height:1.55; color:var(--text-soft); }
.coach-ask   { display:flex; gap:.4rem; align-items:center; flex-shrink:0; flex-wrap:wrap; }
.coach-inp-wrap {
  display:flex; background:var(--surface-2); border:1px solid var(--border);
  border-radius:var(--radius); overflow:hidden; align-items:center;
}
.coach-inp-wrap input {
  background:none; border:none; outline:none; color:var(--text);
  font-family:var(--font-body); font-size:.81rem; padding:.38rem .7rem;
  width:160px; min-width:0;
}
.coach-inp-wrap button {
  background:var(--accent); border:none; padding:.38rem .65rem;
  cursor:pointer; font-size:.82rem; color:#000; font-weight:700;
  flex-shrink:0; transition:background var(--transition);
}
.coach-inp-wrap button:hover { background:var(--accent-hover); }
.coach-resp {
  display:none; background:var(--surface-2); border:1px solid var(--border);
  border-radius:var(--radius-lg); padding:.85rem 1.1rem;
  margin-top:-.55rem; margin-bottom:1.1rem;
  font-size:.84rem; color:var(--text-soft); line-height:1.65; position:relative;
}

/* ── Main grid ── */
.dash-grid {
  display:grid; grid-template-columns:1fr 1fr 1fr;
  gap:1rem; margin-bottom:1.1rem; align-items:start;
}
@media(max-width:960px){ .dash-grid { grid-template-columns:1fr 1fr; } }
@media(max-width:600px){ .dash-grid { grid-template-columns:1fr; } }

/* ── Habit items ── */
.h-item {
  display:flex; align-items:center; gap:.45rem;
  padding:.32rem .4rem; border-radius:6px;
  cursor:pointer; transition:background .12s; font-size:.82rem;
  -webkit-tap-highlight-color:transparent;
}
.h-item:hover { background:var(--surface-2); }
.h-item.done  { color:var(--text-muted); }
.h-item.done .h-name { text-decoration:line-through; }
.h-dot {
  width:18px; height:18px; border-radius:50%;
  border:2px solid var(--border-2); display:flex; align-items:center;
  justify-content:center; font-size:.54rem; font-weight:800;
  flex-shrink:0; transition:all .18s;
}
.h-item.done .h-dot { background:var(--green); border-color:var(--green); color:#fff; }
.h-name { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }

.hab-prog-bar { height:3px; background:var(--surface-3); border-radius:99px; overflow:hidden; margin-bottom:.55rem; }
.hab-prog-fill { height:100%; border-radius:99px; transition:width .4s; }

/* ── Task items ── */
.dash-task {
  display:flex; align-items:center; gap:.4rem;
  padding:.3rem .4rem; border-radius:6px; font-size:.8rem;
  border-left:2px solid var(--border-2);
  background:var(--surface-2); margin-bottom:.28rem;
}
.dash-task.done { opacity:.38; border-left-color:var(--green); }
.dash-task.done .dt-name { text-decoration:line-through; }
.dt-hora { font-family:var(--font-mono); font-size:.62rem; color:var(--text-muted); flex-shrink:0; }
.dt-name { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }

/* ── Obj mini ── */
.obj-mini { display:flex; align-items:center; gap:.5rem; padding:.28rem .35rem; border-radius:6px; font-size:.79rem; }
.obj-dot  { width:7px; height:7px; border-radius:50%; flex-shrink:0; }

/* ── Rutina timeline ── */
.tl-block { border:1px solid var(--border); border-radius:6px; padding:.25rem .45rem; font-size:.69rem; transition:all .2s; }
.tl-block.now  { border-color:var(--accent); background:var(--accent-dim); color:var(--accent); font-weight:600; }
.tl-block.past { opacity:.35; }

/* ── Now card ── */
.now-ring-wrap { flex-shrink:0; position:relative; }
.now-ring-center {
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  text-align:center; line-height:1;
}

/* ── Malo mini ── */
.malo-mini {
  display:flex; align-items:center; gap:.4rem;
  padding:.3rem .4rem; border-radius:6px; font-size:.78rem;
  background:var(--surface-2); border:1px solid var(--border); margin-bottom:.25rem;
}
.malo-badge { font-family:var(--font-mono); font-size:.68rem; font-weight:700; padding:.05rem .3rem; border-radius:99px; }

/* ── Prox item ── */
.prox-item {
  display:flex; align-items:center; gap:.4rem;
  padding:.3rem .35rem; border-radius:7px; font-size:.78rem;
  background:var(--surface-2); border:1px solid var(--border); margin-bottom:.25rem;
}
.prox-lbl { font-size:.58rem; font-family:var(--font-mono); padding:.04rem .28rem; border-radius:99px; background:var(--accent-dim); color:var(--accent); white-space:nowrap; }

/* ── Semana card ── */
.semana-metrics { display:grid; grid-template-columns:repeat(4,1fr) auto; gap:.65rem; align-items:center; margin-bottom:.75rem; }
@media(max-width:500px){ .semana-metrics { grid-template-columns:1fr 1fr; } }
.s-met-lbl  { font-size:.65rem; color:var(--text-muted); margin-bottom:.2rem; }
.s-met-val  { font-family:var(--font-mono); font-size:1.1rem; font-weight:700; line-height:1; }
.s-met-bar  { height:3px; background:var(--surface-3); border-radius:99px; overflow:hidden; margin-top:.25rem; }
#spark-wrap { position:relative; height:80px; }

/* ── Quick check-in ── */
.qci-grid { display:grid; grid-template-columns:1fr 1fr; gap:.55rem; margin-bottom:.55rem; }
.qci-label { display:flex; justify-content:space-between; font-size:.68rem; color:var(--text-muted); margin-bottom:.15rem; }
.qci-val   { font-family:var(--font-mono); font-size:.8rem; font-weight:700; }

/* ── 30d grid ── */
.sum30-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:.5rem; }
@media(max-width:580px){ .sum30-grid { grid-template-columns:repeat(3,1fr); } }

/* ── Coach metric tags (dashboard) ── */
.cm-pill { display:inline-flex; align-items:center; gap:.3rem; padding:.12rem .45rem; border-radius:99px; font-size:.75rem; font-weight:700; font-family:var(--font-mono); margin:.1rem .1rem; vertical-align:middle; }
.cm-bar-wrap { margin:.35rem 0; }
.cm-bar-label { display:flex; justify-content:space-between; font-size:.75rem; margin-bottom:.2rem; }
.cm-bar-track { height:6px; background:var(--surface-3); border-radius:99px; overflow:hidden; }
.cm-bar-fill  { height:100%; border-radius:99px; transition:width .4s; }
.cm-rx    { background:var(--indigo-dim); border-left:3px solid var(--indigo); padding:.5rem .75rem; border-radius:0 var(--radius) var(--radius) 0; font-size:.82rem; margin:.3rem 0; }
.cm-alert { background:rgba(245,158,11,.08); border-left:3px solid var(--accent); padding:.5rem .75rem; border-radius:0 var(--radius) var(--radius) 0; font-size:.82rem; margin:.3rem 0; }
.cm-ok    { background:var(--green-dim); border-left:3px solid var(--green); padding:.5rem .75rem; border-radius:0 var(--radius) var(--radius) 0; font-size:.82rem; margin:.3rem 0; }
</style>

<%
var _ci      = locals.coachInsight || { texto: '', tipo: 'neutro' };
var _ciColor = _ci.tipo==='positivo'?'var(--green)':_ci.tipo==='alerta'?'var(--accent)':'var(--indigo)';
var _ciBg    = _ci.tipo==='positivo'?'rgba(34,197,94,.06)':_ci.tipo==='alerta'?'rgba(245,158,11,.06)':'rgba(99,102,241,.06)';
var _ciBrd   = _ci.tipo==='positivo'?'rgba(34,197,94,.22)':_ci.tipo==='alerta'?'rgba(245,158,11,.25)':'rgba(99,102,241,.25)';
var _wc      = locals.weekCheckins || [];
var _tareas  = (locals.tareasHoy||[]).concat(locals.tareasAgendaHoy||[]);
var _rep     = locals.reportSummary;
var _racha   = locals.checkinRacha || 0;
var tc       = locals.todayCheckin;
var _score   = locals.generalScore || 0;
var _scoreCol = _score>=70?'var(--green)':_score>=40?'var(--accent)':'var(--red)';
%>

<!-- ── ALERTAS ── -->
<% if (alerts && alerts.length > 0) { %>
<div style="margin-bottom:.9rem;display:flex;flex-direction:column;gap:.3rem">
  <% alerts.forEach(function(a){ %><div class="alert alert-<%= a.type %>">⚠ <%= a.message %></div><% }); %>
</div>
<% } %>

<!-- ══ HERO ══ -->
<div class="dash-hero">
  <!-- Score ring -->
  <div class="hero-score-wrap">
    <svg width="90" height="90" viewBox="0 0 90 90">
      <circle cx="45" cy="45" r="36" fill="none" stroke="var(--surface-3)" stroke-width="7"/>
      <circle cx="45" cy="45" r="36" fill="none"
        stroke="<%= _scoreCol %>"
        stroke-width="7" stroke-dasharray="226.2"
        stroke-dashoffset="<%= Math.round(226.2*(1-_score/100)) %>"
        stroke-linecap="round" transform="rotate(-90 45 45)"/>
    </svg>
    <div class="hero-score-center">
      <div style="font-family:var(--font-mono);font-size:1.35rem;font-weight:700;color:<%= _scoreCol %>"><%= _score||'—' %></div>
      <div style="font-size:.52rem;color:var(--text-muted)">/100</div>
    </div>
  </div>

  <!-- Info -->
  <div class="hero-info">
    <div class="hero-greeting">MI ESTADO HOY</div>
    <div class="hero-date" id="fecha-reloj">—</div>
    <div class="hero-badges">
      <% if (tc) { %>
      <span class="badge badge-green" style="font-size:.66rem">✓ Chequeo registrado</span>
      <% } else { %>
      <span class="badge badge-muted" style="font-size:.66rem">Sin chequeo hoy</span>
      <% } %>
      <% if (_racha > 0) { %>
      <span style="display:inline-flex;align-items:center;gap:.25rem;padding:.18rem .5rem;border-radius:99px;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.25);font-size:.68rem;font-family:var(--font-mono);font-weight:700;color:var(--accent)">
        🔥 <%= _racha %>d
      </span>
      <% } %>
      <% if (tc && tc.sleep_hours) { %>
      <span style="font-size:.7rem;color:var(--text-muted)">😴 <%= tc.sleep_hours %>h</span>
      <% } %>
      <span style="font-size:.75rem;font-weight:600;color:<%= _scoreCol %>">
        <%= _score>=80?'Excelente 🚀':_score>=65?'Muy bien 😊':_score>=50?'Bien 🙂':_score>=35?'Regular 😐':tc?'Difícil 😔':'Sin datos' %>
      </span>
    </div>
  </div>

  <!-- Actions -->
  <div class="hero-actions">
    <a href="/checkin" class="btn btn-primary btn-sm" style="white-space:nowrap">
      <%= tc ? '✏️ Editar chequeo' : '+ Chequeo de hoy' %>
    </a>
    <a href="/mejora" class="btn btn-ghost btn-sm" style="font-size:.74rem;text-align:center">Ver análisis →</a>
  </div>
</div>

<!-- ══ VITALS ══ -->
<%
var vitals = [
  { icon:'⚡', val: tc?tc.energy:'—',           lbl:'Energía',  color:'#f59e0b', pct: tc?tc.energy*10:0 },
  { icon:'😊', val: tc?tc.mood:'—',             lbl:'Ánimo',    color:'#a78bfa', pct: tc?tc.mood*10:0 },
  { icon:'🧠', val: tc?tc.clarity:'—',          lbl:'Claridad', color:'#38bdf8', pct: tc?tc.clarity*10:0 },
  { icon:'😰', val: tc?tc.anxiety:'—',          lbl:'Ansiedad', color: tc&&tc.anxiety>=7?'#ef4444':'#22c55e', pct: tc?(10-tc.anxiety)*10:0 },
  { icon:'😴', val: tc?(tc.sleep_hours+'h'):'—',lbl:'Sueño',    color: tc&&tc.sleep_hours>=7?'#22c55e':tc&&tc.sleep_hours>=6?'#f59e0b':'#ef4444', pct: tc?Math.min(100,tc.sleep_hours/9*100):0 },
];
%>
<div class="vitals-strip">
<% vitals.forEach(function(v) { %>
<div class="vital-card" style="border-bottom:2px solid <%= v.color %>22">
  <div class="vital-icon"><%= v.icon %></div>
  <div class="vital-val" style="color:<%= v.color %>">
    <%= v.val %><% if(v.val !== '—' && v.lbl !== 'Sueño'){ %><span style="font-size:.65rem;color:var(--text-muted)">/10</span><% } %>
  </div>
  <div class="vital-lbl"><%= v.lbl %></div>
  <div class="vital-bar"><div class="vital-bar-fill" style="width:<%= v.pct %>%;background:<%= v.color %>"></div></div>
</div>
<% }); %>
</div>

<!-- ══ COACH BANNER ══ -->
<div class="coach-banner" style="background:<%= _ciBg %>;border-color:<%= _ciBrd %>">
  <div class="coach-icon"><%= _ci.tipo==='positivo'?'🟢':_ci.tipo==='alerta'?'⚠️':'🧠' %></div>
  <div class="coach-body">
    <div class="coach-label" style="color:<%= _ciColor %>">Coach · Insight del día</div>
    <div class="coach-txt"><%= _ci.texto %></div>
  </div>
  <div class="coach-ask">
    <div class="coach-inp-wrap">
      <input type="text" id="dash-chat-inp" placeholder="Pregunta al coach…" maxlength="200"
        onkeydown="if(event.key==='Enter')dashCoachSend()" />
      <button onclick="dashCoachSend()">→</button>
    </div>
    <a href="/coach" class="btn btn-ghost btn-sm" style="font-size:.74rem;white-space:nowrap">Completo →</a>
  </div>
</div>
<div class="coach-resp" id="dash-coach-resp">
  <button onclick="this.parentElement.style.display='none'" style="position:absolute;top:.5rem;right:.65rem;background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1rem">✕</button>
  <div style="font-family:var(--font-mono);font-size:.58rem;text-transform:uppercase;letter-spacing:.1em;color:var(--accent);margin-bottom:.35rem">🧠 Coach responde</div>
  <div id="dash-coach-resp-txt"></div>
</div>

<!-- ══ MAIN 3-COL GRID ══ -->
<div class="dash-grid">

  <!-- AHORA -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">🕐 Ahora</h2>
      <a href="/rutina" class="btn btn-ghost btn-sm" style="font-size:.7rem">Rutina →</a>
    </div>
    <div style="display:flex;align-items:center;gap:.85rem;margin-bottom:.65rem">
      <div class="now-ring-wrap">
        <svg width="52" height="52" viewBox="0 0 52 52">
          <circle cx="26" cy="26" r="20" fill="none" stroke="var(--surface-3)" stroke-width="5"/>
          <circle id="progreso-arc" cx="26" cy="26" r="20" fill="none" stroke="var(--accent)"
            stroke-width="5" stroke-dasharray="125.7" stroke-dashoffset="125.7"
            stroke-linecap="round" transform="rotate(-90 26 26)"/>
        </svg>
        <div class="now-ring-center">
          <span id="progreso-pct" style="font-family:var(--font-mono);font-size:.52rem;color:var(--text-muted)">—</span>
        </div>
      </div>
      <div style="flex:1;min-width:0">
        <div style="font-size:.57rem;text-transform:uppercase;letter-spacing:.07em;color:var(--text-muted)">En curso</div>
        <div id="bloque-actual-nombre" style="font-size:.88rem;font-weight:600;color:var(--accent);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">—</div>
        <div id="bloque-actual-hora" style="font-size:.65rem;color:var(--text-muted);margin-bottom:.25rem"></div>
        <div style="font-size:.57rem;text-transform:uppercase;letter-spacing:.07em;color:var(--text-muted)">Siguiente</div>
        <div id="bloque-siguiente-nombre" style="font-size:.76rem;color:var(--text-soft);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">—</div>
        <div id="bloque-siguiente-hora" style="font-size:.62rem;color:var(--text-muted)"></div>
      </div>
    </div>
    <div id="rutina-timeline" style="display:flex;flex-wrap:wrap;gap:.3rem;padding-top:.6rem;border-top:1px solid var(--border)">
      <span style="font-size:.72rem;color:var(--text-muted)">Cargando…</span>
    </div>
  </div>

  <!-- HÁBITOS -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">✅ Hábitos</h2>
      <div style="display:flex;align-items:center;gap:.45rem">
        <span style="font-family:var(--font-mono);font-size:.7rem;color:<%= habitCompletionToday>=70?'var(--green)':habitCompletionToday>=40?'var(--accent)':'var(--red)' %>"><%= habitCompletionToday %>%</span>
        <a href="/habits" class="btn btn-ghost btn-sm" style="font-size:.7rem">Ver →</a>
      </div>
    </div>
    <% if (habits.length === 0) { %>
    <p class="empty-state">Sin hábitos. <a href="/habits">Crear →</a></p>
    <% } else { %>
    <div class="hab-prog-bar">
      <div class="hab-prog-fill" style="width:<%= habitCompletionToday %>%;background:<%= habitCompletionToday>=70?'var(--green)':habitCompletionToday>=40?'var(--accent)':'var(--red)' %>"></div>
    </div>
    <div style="font-size:.68rem;color:var(--text-muted);margin-bottom:.45rem"><%= completedToday.length %>/<%= habits.length %> completados hoy</div>
    <div style="display:flex;flex-direction:column;gap:.02rem">
      <% habits.slice(0,9).forEach(function(h){ %>
      <div class="h-item <%= completedToday.includes(h.id)?'done':'' %>" id="dash-h-<%= h.id %>" onclick="dashToggle(<%= h.id %>)">
        <div class="h-dot" id="dash-dot-<%= h.id %>"><%= completedToday.includes(h.id)?'✓':'' %></div>
        <span class="h-name"><%= h.name %></span>
        <% var st = habitStreaks.find(function(s){return s.name===h.name}); %>
        <% if (st && st.streak>1) { %><span style="font-size:.6rem;color:var(--accent)">🔥<%= st.streak %>d</span><% } %>
      </div>
      <% }); %>
      <% if (habits.length > 9) { %>
      <div style="font-size:.68rem;color:var(--text-muted);padding:.15rem .4rem">+<%= habits.length-9 %> más</div>
      <% } %>
    </div>
    <% } %>
  </div>

  <!-- TAREAS + OBJETIVOS -->
  <div>
    <!-- Tareas hoy -->
    <div class="card" style="margin-bottom:.75rem">
      <div class="card-header">
        <h2 class="card-title">📋 Tareas hoy</h2>
        <a href="/agenda" class="btn btn-ghost btn-sm" style="font-size:.7rem">Agenda →</a>
      </div>
      <% if (_tareas.length === 0) { %>
      <p class="empty-state">Sin tareas. <a href="/agenda">Agregar →</a></p>
      <% } else { %>
        <% _tareas.slice(0,6).forEach(function(t){ %>
        <div class="dash-task <%= t.completado?'done':'' %>">
          <span style="font-size:.75rem;flex-shrink:0;color:<%= t.completado?'var(--green)':'var(--text-muted)' %>"><%= t.completado?'✓':'○' %></span>
          <% if (t.hora) { %><span class="dt-hora"><%= t.hora %></span><% } %>
          <span class="dt-name"><%= t.nombre %></span>
        </div>
        <% }); %>
        <% var _pend = _tareas.filter(function(t){return !t.completado}).length; %>
