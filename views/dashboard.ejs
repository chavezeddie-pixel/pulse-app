<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
var TODAY_DASH = '<%= today %>';
var DIAS_KEY   = ['domingo','lunes','martes','miercoles','jueves','viernes','sabado'];
var DIAS_LABEL = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
var MESES = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
var rutina = {};

// ── Rutina + reloj ──
function cargarRutina() {
  fetch('/rutina.json')
    .then(function(r){ return r.json(); })
    .then(function(d){
      rutina = d;
      actualizarReloj();
      renderTimeline(rutina[DIAS_KEY[new Date().getDay()]] || []);
    })
    .catch(function(){ actualizarReloj(); });
}

function actualizarReloj() {
  var now = new Date();
  var h = String(now.getHours()).padStart(2,'0');
  var m = String(now.getMinutes()).padStart(2,'0');
  var el = document.getElementById('fecha-reloj');
  if (el) el.textContent = DIAS_LABEL[now.getDay()] + ', ' + now.getDate() + ' de ' + MESES[now.getMonth()] + ' · ' + h + ':' + m;

  var diaKey  = DIAS_KEY[now.getDay()];
  var bloques = rutina[diaKey] || [];
  var min     = now.getHours()*60 + now.getMinutes();
  var actual = null, siguiente = null;
  for (var i = 0; i < bloques.length; i++) {
    var hI = parseInt(bloques[i].inicio.split(':')[0])*60 + parseInt(bloques[i].inicio.split(':')[1]);
    var hF = parseInt(bloques[i].fin.split(':')[0])*60   + parseInt(bloques[i].fin.split(':')[1]);
    if (min >= hI && min < hF) { actual = Object.assign({}, bloques[i], {minI:hI, minF:hF}); siguiente = bloques[i+1] || null; break; }
    if (min < hI && !siguiente) siguiente = bloques[i];
  }
  var _set = function(id, v){ var e=document.getElementById(id); if(e) e.textContent=v; };
  _set('bloque-actual-nombre',   actual    ? actual.bloque    : 'Sin bloque activo');
  _set('bloque-actual-hora',     actual    ? actual.inicio + ' — ' + actual.fin : '');
  _set('bloque-siguiente-nombre',siguiente ? siguiente.bloque : 'Sin más bloques');
  _set('bloque-siguiente-hora',  siguiente ? 'A las ' + siguiente.inicio : '');

  var arc = document.getElementById('progreso-arc');
  var pct = document.getElementById('progreso-pct');
  if (actual && arc) {
    var p = Math.round(((min - actual.minI) / (actual.minF - actual.minI)) * 100);
    arc.setAttribute('stroke-dashoffset', Math.round(125.7 * (1 - p/100)));
    if (pct) pct.textContent = p + '%';
  } else if (arc) {
    arc.setAttribute('stroke-dashoffset', '125.7');
    if (pct) pct.textContent = '—';
  }
}

function renderTimeline(bloques) {
  var tl = document.getElementById('rutina-timeline');
  if (!tl) return;
  if (!bloques.length) {
    tl.innerHTML = '<span style="font-size:.72rem;color:var(--text-muted)">Sin bloques. <a href="/rutina">Crear →</a></span>';
    return;
  }
  var now = new Date(), min = now.getHours()*60 + now.getMinutes();
  tl.innerHTML = bloques.map(function(b) {
    var hI = parseInt(b.inicio.split(':')[0])*60 + parseInt(b.inicio.split(':')[1]);
    var hF = parseInt(b.fin.split(':')[0])*60   + parseInt(b.fin.split(':')[1]);
    var isNow = min >= hI && min < hF, isPast = min >= hF;
    return '<div class="tl-block' + (isNow?' now':isPast?' past':'') + '">' +
      '<div style="font-size:.54rem;font-family:monospace;opacity:.7">' + b.inicio + '–' + b.fin + '</div>' +
      '<div style="font-size:.68rem">' + (isNow ? '▶ ' : '') + b.bloque + '</div></div>';
  }).join('');
}

// ── Secciones colapsables ──
function toggleQCI() {
  var p = document.getElementById('qci-panel');
  var a = document.getElementById('qci-arrow');
  var v = p.style.display !== 'none';
  p.style.display = v ? 'none' : 'block';
  a.textContent = v ? '▸' : '▾';
}
function toggleSec(panelId, arrowId) {
  var p = document.getElementById(panelId);
  var a = document.getElementById(arrowId);
  var v = p.style.display !== 'none';
  p.style.display = v ? 'none' : 'block';
  a.textContent = v ? '▸' : '▾';
}

// ── Quick check-in ──
function guardarQuickCheckin() {
  var body = {
    energy:         document.getElementById('qci-energy').value,
    mood:           document.getElementById('qci-mood').value,
    clarity:        document.getElementById('qci-clarity').value,
    anxiety:        document.getElementById('qci-anxiety').value,
    sleep_hours:    document.getElementById('qci-sleep').value,
    did_exercise:   document.getElementById('qci-exercise').checked ? 1 : 0,
    did_study:      document.getElementById('qci-study').checked ? 1 : 0,
    completed_main: document.getElementById('qci-main').checked ? 1 : 0,
  };
  apiFetch('/checkin/quick', { method:'POST', body: body })
    .then(function() {
      showToast('✓ Check-in guardado', 'success');
      setTimeout(function() { location.reload(); }, 900);
    });
}

// ── Toggle hábito ──
function dashToggle(id) {
  var item = document.getElementById('dash-h-' + id);
  var dot  = document.getElementById('dash-dot-' + id);
  apiFetch('/habits/' + id + '/toggle', {
    method: 'POST',
    body: { date: TODAY_DASH }
  }).then(function(d) {
    if (item) item.classList.toggle('done', d.completado);
    if (dot)  dot.textContent = d.completado ? '✓' : '';
    if (d.completado) showToast('Hábito completado ✓', 'success', 1600);
  });
}

// ── Sparkline ──
<% if (_wc.length >= 2) { %>
(function(){
  var chartData = <%- locals.chartData || '{}' %>;
  if (!chartData.labels) return;
  var ctx = document.getElementById('spark-chart');
  if (!ctx) return;
  var isDark = !document.body.classList.contains('light');
  var gridColor = isDark ? 'rgba(255,255,255,.05)' : 'rgba(0,0,0,.06)';
  var tickColor = isDark ? 'rgba(255,255,255,.35)' : 'rgba(0,0,0,.35)';
  new Chart(ctx, {
    type: 'line',
    data: {
      labels: chartData.labels,
      datasets: [
        { label:'Energía',  data:chartData.energy,  borderColor:'#f59e0b', borderWidth:2, pointRadius:2, tension:.4, fill:false },
        { label:'Ánimo',    data:chartData.mood,    borderColor:'#a78bfa', borderWidth:2, pointRadius:2, tension:.4, fill:false },
        { label:'Ansiedad', data:chartData.anxiety, borderColor:'#fb7185', borderWidth:1.5, pointRadius:2, tension:.4, fill:false, borderDash:[3,3] },
      ]
    },
    options: {
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{ display:true, labels:{ color: tickColor, font:{size:10}, boxWidth:12 } } },
      scales:{
        x:{ ticks:{color:tickColor, font:{size:9}}, grid:{display:false} },
        y:{ min:0, max:10, ticks:{color:tickColor, font:{size:9}, stepSize:5}, grid:{color:gridColor} }
      }
    }
  });
})();
<% } %>

// ── Coach IA mini-chat ──
function renderCoachTags(text) {
  text = text
    .replace(/\[\[M:(.*?):(.*?):(.*?)\]\]/g, function(_,l,v,c){
      var colors={green:'#22c55e',red:'#ef4444',amber:'#f59e0b',accent:'var(--accent)',muted:'var(--text-muted)',indigo:'#6366f1'};
      var col = colors[c] || colors.accent;
      return '<span class="cm-pill" style="background:'+col+'22;color:'+col+'">'+l+' <strong>'+v+'</strong></span>';
    })
    .replace(/\[\[BAR:(.*?):(.*?):(.*?)\]\]/g, function(_,l,p,c){
      var colors={green:'#22c55e',red:'#ef4444',amber:'#f59e0b',accent:'var(--accent)',indigo:'#6366f1'};
      var col = colors[c] || colors.accent;
      return '<div class="cm-bar-wrap"><div class="cm-bar-label"><span>'+l+'</span><span style="color:'+col+'">'+p+'%</span></div><div class="cm-bar-track"><div class="cm-bar-fill" style="width:'+Math.min(100,p)+'%;background:'+col+'"></div></div></div>';
    })
    .replace(/\[\[RX:(.*?)\]\]/g,    '<div class="cm-rx">📋 $1</div>')
    .replace(/\[\[ALERT:(.*?)\]\]/g, '<div class="cm-alert">⚠️ $1</div>')
    .replace(/\[\[OK:(.*?)\]\]/g,    '<div class="cm-ok">✅ $1</div>');
  return text.replace(/\n/g, '<br>');
}

function dashCoachSend() {
  var inp = document.getElementById('dash-chat-inp');
  var msg = inp.value.trim();
  if (!msg) return;
  inp.value = '';
  inp.placeholder = 'Pensando…';
  inp.disabled = true;
  progressStart();
  fetch('/coach/chat', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ mensaje: msg })
  })
  .then(function(r){ return r.json(); })
  .then(function(d) {
    progressDone();
    inp.disabled = false;
    inp.placeholder = 'Pregunta al coach…';
    var resp = document.getElementById('dash-coach-resp');
    var txt  = document.getElementById('dash-coach-resp-txt');
    if (txt) txt.innerHTML = renderCoachTags(d.respuesta || 'Sin respuesta.');
    if (resp) { resp.style.display = 'block'; resp.scrollIntoView({ behavior:'smooth', block:'nearest' }); }
  })
  .catch(function() {
    progressDone();
    inp.disabled = false;
    inp.placeholder = 'Pregunta al coach…';
    showToast('Error al conectar con el coach', 'error');
  });
}

cargarRutina();
setInterval(actualizarReloj, 60000);
</script>

