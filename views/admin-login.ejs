<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pulse — Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
  <style>
    body { background:#1a1a2e; color:#fef9ef; font-family:'Inter',sans-serif; min-height:100vh; display:flex; align-items:center; justify-content:center; }
    .admin-box { max-width:380px; width:100%; padding:2rem; text-align:center; }
    .admin-box h1 { font-size:1.5rem; font-weight:800; margin:0 0 .3rem; }
    .admin-box .sub { color:#9a8e7e; font-size:.85rem; margin-bottom:1.5rem; }
    .admin-form { background:rgba(254,249,239,.03); border:1px solid rgba(254,249,239,.08); border-radius:16px; padding:1.5rem; }
    .admin-input { width:100%; padding:.7rem 1rem; border-radius:10px; border:1px solid rgba(254,249,239,.12); background:rgba(254,249,239,.05); color:#fef9ef; font-size:1.4rem; font-family:monospace; text-align:center; letter-spacing:.5em; margin-bottom:1rem; box-sizing:border-box; }
    .admin-input:focus { outline:none; border-color:#f4845f; }
    .admin-btn { width:100%; padding:.75rem; border-radius:10px; border:none; background:linear-gradient(135deg, #f4845f, #f9c74f); color:#1a1a2e; font-size:.95rem; font-weight:700; font-family:inherit; cursor:pointer; transition:all .2s; }
    .admin-btn:hover { box-shadow:0 4px 16px rgba(244,132,95,.3); transform:translateY(-1px); }
    .error { color:#f87171; font-size:.82rem; margin-bottom:.8rem; }
    .back-link { display:inline-block; margin-top:1.2rem; color:#6b5f52; font-size:.8rem; text-decoration:none; }
    .back-link:hover { color:#9a8e7e; }
    .lock-icon { font-size:2.5rem; margin-bottom:.8rem; }
  </style>
</head>
<body>
  <div class="admin-box">
    <div class="lock-icon">🔒</div>
    <h1>Acceso Admin</h1>
    <p class="sub">Ingresa tu PIN para acceder a tu cuenta personal.</p>

    <form class="admin-form" action="/admin/login" method="POST">
      <% if (locals.error) { %>
        <div class="error"><%= error %></div>
      <% } %>
      <input type="password" name="pin" class="admin-input" placeholder="PIN" maxlength="10" autofocus required />
      <button type="submit" class="admin-btn">Entrar</button>
    </form>

    <a href="/demo" class="back-link">← Volver a la demo</a>
  </div>
</body>
</html>
